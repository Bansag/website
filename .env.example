# ──────────────────────────────────────────────────
# Bansag Website — Environment Variables
# ──────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in values.
# NEVER commit .env or .env.local to version control.
#
# Vite exposes variables prefixed with VITE_ to client code.
# Do NOT put secrets here — this is a public frontend app.
# ──────────────────────────────────────────────────

# Contact email (optional override)
# VITE_CONTACT_EMAIL=bansag.ph@gmail.com

# Analytics ID (future use)
# VITE_GA_ID=
